{
    "name": "@playcanvas/editor",
    "version": "2.26.6",
    "description": "The PlayCanvas Editor Frontend",
    "keywords": [
        "editor",
        "html5",
        "javascript",
        "pcui",
        "playcanvas",
        "webgl",
        "webgpu",
        "webxr"
    ],
    "homepage": "https://playcanvas.com",
    "bugs": {
        "url": "https://github.com/playcanvas/editor/issues"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/playcanvas/editor.git"
    },
    "license": "MIT",
    "author": "PlayCanvas <support@playcanvas.com>",
    "type": "module",
    "main": "js/editor/index.js",
    "scripts": {
        "build": "cross-env NODE_ENV=production vite build",
        "develop": "concurrently --kill-others \"npm run watch\" \"npm run serve\"",
        "fmt": "prettier --check .",
        "fmt:fix": "prettier --write .",
        "lint": "stylelint sass && eslint",
        "lint:fix": "stylelint sass --fix && eslint --fix",
        "serve": "serve dist -p 3487 --cors",
        "test": "mocha",
        "test:api": "rollup -c test/editor-api/rollup.test.config.mjs && karma start test/editor-api/karma.conf.cjs --single-run",
        "typecheck": "tsc",
        "watch": "cross-env NODE_ENV=development vite build --watch"
    },
    "browserslist": [
        ">0.3%, defaults"
    ],
    "dependencies": {
        "@playcanvas/attribute-parser": "^1.11.0"
    },
    "devDependencies": {
        "@jsquash/avif": "1.3.0",
        "@jsquash/jpeg": "1.6.0",
        "@jsquash/png": "2.2.0",
        "@jsquash/webp": "1.5.0",
        "@playcanvas/eslint-config": "3.0.0-beta.8",
        "@playcanvas/observer": "1.7.1",
        "@playcanvas/pcui": "6.1.4",
        "@playcanvas/pcui-graph": "5.2.5",
        "@rollup/plugin-commonjs": "28.0.9",
        "@rollup/plugin-node-resolve": "15.3.1",
        "@rollup/plugin-swc": "0.4.0",
        "@sentry/browser": "^10.48.0",
        "@swc/core": "1.15.18",
        "@types/sharedb": "3.3.13",
        "autoprefixer": "10.4.27",
        "chai": "5.3.3",
        "concurrently": "10.0.3",
        "cross-env": "7.0.3",
        "dexie": "4.3.0",
        "esbuild": "0.28.1",
        "esbuild-plugin-polyfill-node": "0.3.0",
        "eslint": "9.39.4",
        "filenamify": "6.0.0",
        "highlight.js": "11.11.1",
        "karma": "6.4.4",
        "karma-chrome-launcher": "3.2.0",
        "karma-mocha": "2.0.1",
        "karma-spec-reporter": "0.0.36",
        "markdown-it": "14.2.0",
        "mocha": "11.7.5",
        "monaco-editor": "0.47.0",
        "monaco-themes": "0.4.8",
        "ot-text": "github:playcanvas/ot-text",
        "playcanvas": "2.20.6",
        "postcss": "8.5.12",
        "prettier": "3.9.4",
        "rollup": "4.59.0",
        "rollup-plugin-polyfill-node": "0.13.0",
        "sass-embedded": "1.98.0",
        "serve": "14.2.6",
        "sharedb": "3.3.2",
        "sinon": "17.0.1",
        "stylelint": "16.26.1",
        "stylelint-config-standard-scss": "13.1.0",
        "ts-node": "10.9.2",
        "typescript": "5.9.3",
        "vite": "7.3.5"
    },
    "engines": {
        "node": ">=22.22.0"
    }
}
