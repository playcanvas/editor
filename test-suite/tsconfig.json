{
    "compilerOptions": {
        "lib": ["ESNext", "DOM"],
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "node",
        "allowJs": true,
        "strict": true,
        "skipLibCheck": true,
        "noEmit": true,
        "baseUrl": ".",
        "paths": {
            "@playcanvas/editor-api": ["./.editor-api-types"]
        }
    },
    "include": ["src", "test", "lib", "globals.d.ts"],
    "exclude": ["node_modules", "out"]
}
